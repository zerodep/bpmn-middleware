{
  "name": "bpmn-middleware",
  "version": "0.19.0",
  "description": "BPMN engine express middleware",
  "type": "module",
  "main": "./dist/main.cjs",
  "module": "./src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/main.cjs",
      "types": "./types/index.d.ts"
    }
  },
  "scripts": {
    "test": "mocha",
    "posttest": "npm run lint && npm run dist && npm run test:md",
    "lint": "eslint . --cache && prettier . --check --cache",
    "prepack": "npm run dist",
    "cov:html": "c8 -r html -r text mocha",
    "test:lcov": "c8 -r lcov mocha && npm run lint",
    "test:md": "texample ./README.md,./docs/API.md,./example/README.md",
    "dist": "dts-buddy && rollup -c"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zerodep/bpmn-middleware.git"
  },
  "keywords": [
    "bpmn",
    "bpmn-engine",
    "express",
    "middleware",
    "call activity"
  ],
  "author": {
    "name": "Zerodep AB",
    "url": "https://github.com/zerodep"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zerodep/bpmn-middleware/issues"
  },
  "homepage": "https://github.com/zerodep/bpmn-middleware#readme",
  "devDependencies": {
    "@aller/express-swagger": "^0.0.9",
    "@eslint/js": "^10.0.1",
    "@onify/flow-extensions": "^9.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@types/bpmn-moddle": "^5.1.11",
    "@types/debug": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/multer": "^2.0.0",
    "@types/supertest": "^7.2.0",
    "c8": "^11.0.0",
    "camunda-bpmn-moddle": "^7.0.1",
    "chai": "^6.0.1",
    "chronokinesis": "^8.0.0",
    "dts-buddy": "^0.7.0",
    "eslint": "^10.3.0",
    "express": "^5.1.0",
    "express-4": "npm:express@^4.21.2",
    "form-data": "^4.0.0",
    "globals": "^17.0.0",
    "mocha": "^11.0.1",
    "mocha-cakes-2": "^3.3.0",
    "nock": "^14.0.0",
    "prettier": "^3.3.3",
    "rollup": "^4.17.2",
    "supertest": "^7.0.0",
    "texample": "^1.0.2"
  },
  "dependencies": {
    "lru-cache": "^11.2.6",
    "multer": "^2.0.0"
  },
  "peerDependencies": {
    "@0dep/piso": ">=2",
    "bpmn-elements": ">=17",
    "bpmn-engine": ">=15",
    "debug": "4.x",
    "express": ">=4",
    "smqp": ">=9"
  },
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    },
    "mocha": {
      "yargs": "^18.0.0"
    }
  },
  "files": [
    "src/",
    "dist/",
    "types/"
  ],
  "workspaces": [
    "example"
  ],
  "c8": {
    "include": [
      "src/",
      "example/"
    ]
  },
  "scarfSettings": {
    "enabled": false
  }
}
